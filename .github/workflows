name: Batch Render — Multiple Products

# Dán danh sách link Amazon (mỗi dòng 1 sản phẩm) → tất cả render song song.
# Kết quả: toàn bộ video tự upload vào Dropbox cùng lúc.
#
# Định dạng input (mỗi dòng):
#   https://amazon.com/dp/B0XXXXXXX | tên-file-dropbox
#   https://amazon.com/dp/B0YYYYYYY          <- tên file tự sinh từ ASIN
#   # dòng bắt đầu bằng # sẽ bị bỏ qua

on:
  workflow_dispatch:
    inputs:
      products:
        description: "Danh sách sản phẩm — mỗi dòng 1 link (tuỳ chọn: link | tên-file)"
        required: true
        type: string
      ai_provider:
        description: "AI provider để viết narration"
        required: false
        default: "deepseek"
        type: choice
        options:
          - deepseek
          - claude
          - openai

jobs:

  setup:
    runs-on: ubuntu-latest
    outputs:
      matrix: ${{ steps.parse.outputs.matrix }}
      count:  ${{ steps.parse.outputs.count }}
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Parse product list into matrix
        id: parse
        env:
          PRODUCTS: ${{ github.event.inputs.products }}
        run: python3 scripts/parse_products.py

      - name: Print summary
        run: echo "### Batch render — ${{ steps.parse.outputs.count }} sản phẩm song song" >> $GITHUB_STEP_SUMMARY

  render:
    needs: setup
    runs-on: ubuntu-latest
    timeout-minutes: 35
    strategy:
      matrix: ${{ fromJson(needs.setup.outputs.matrix) }}
      fail-fast: false
    env:
      PRODUCT_URL:  ${{ matrix.url }}
      PRODUCT_NAME: ${{ matrix.name }}

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Node.js 22
        uses: actions/setup-node@v4
        with:
          node-version: 22

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install ffmpeg
        run: sudo apt-get update && sudo apt-get install -y ffmpeg

      - name: Install hyperframes CLI
        run: npm install hyperframes --no-save --ignore-scripts

      - name: Install TTS engine (Kokoro)
        run: pip install kokoro-onnx soundfile --break-system-packages

      - name: Download headless Chrome
        run: npx hyperframes browser ensure

      - name: Load narration (pre-written if exists, else generate via AI)
        env:
          AMAZON_URL:        ${{ matrix.url }}
          AI_PROVIDER:       ${{ github.event.inputs.ai_provider }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          OPENAI_API_KEY:    ${{ secrets.OPENAI_API_KEY }}
          DEEPSEEK_API_KEY:  ${{ secrets.DEEPSEEK_API_KEY }}
        run: |
          NARR_DIR="narrations/${PRODUCT_NAME}"
          if [ -d "$NARR_DIR" ] && [ $(ls "$NARR_DIR"/narration-*.txt 2>/dev/null | wc -l) -eq 26 ]; then
            echo "Found pre-written narration for '$PRODUCT_NAME' — dùng luôn, không gọi AI."
            cp "$NARR_DIR"/narration-*.txt assets/
            echo "=== Narration loaded ==="
            for f in assets/narration-*.txt; do echo "$(basename $f): $(cat $f)"; done
          else
            echo "Không có narration sẵn cho '$PRODUCT_NAME' — gọi AI để viết..."
            python3 scripts/generate_narration.py "$AMAZON_URL"
          fi

      - name: Generate TTS audio (26 chunks)
        run: |
          for f in assets/narration-*.txt; do
            n=$(basename "$f" .txt | sed 's/narration-//')
            echo "=== Chunk $n: $(cat $f) ==="
            npx hyperframes tts "$f" -o "voice-${n}.wav" -v af_heart
          done

      - name: Concatenate chunks into single audio file
        run: |
          : > concat-list.txt
          for f in voice-*.wav; do echo "file '$f'" >> concat-list.txt; done
          ffmpeg -f concat -safe 0 -i concat-list.txt -c:a pcm_s16le -ar 24000 -ac 1 -y narration-full.wav
          ffprobe -v quiet -show_entries format=duration -of default=noprint_wrappers=1 narration-full.wav

      - name: Sync timeline to real audio durations
        run: python3 scripts/build_timing.py

      - name: Fetch product images (Dropbox first, then fallback)
        env:
          DROPBOX_APP_KEY:      ${{ secrets.DROPBOX_APP_KEY }}
          DROPBOX_APP_SECRET:   ${{ secrets.DROPBOX_APP_SECRET }}
          DROPBOX_REFRESH_TOKEN: ${{ secrets.DROPBOX_REFRESH_TOKEN }}
        run: |
          UA="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
          ASIN=$(echo "$PRODUCT_URL" | grep -oP '(?:/dp/|/product/|/gp/product/)\K[A-Z0-9]{10}' | head -1)
          echo "ASIN: ${ASIN:-(none)}"

          DBX_TOKEN=""
          if [ -n "$ASIN" ] && [ -n "$DROPBOX_APP_KEY" ]; then
            DBX_TOKEN=$(curl -s https://api.dropbox.com/oauth2/token \
              -d grant_type=refresh_token \
              -d refresh_token="$DROPBOX_REFRESH_TOKEN" \
              -d client_id="$DROPBOX_APP_KEY" \
              -d client_secret="$DROPBOX_APP_SECRET" \
              | python3 -c "import sys,json; print(json.load(sys.stdin).get('access_token',''))")
          fi

          ALL_PATHS=""
          if [ -n "$DBX_TOKEN" ] && [ -n "$ASIN" ]; then
            LIST_JSON=$(curl -s -X POST https://api.dropboxapi.com/2/files/list_folder \
              --header "Authorization: Bearer $DBX_TOKEN" \
              --header "Content-Type: application/json" \
              --data "{\"path\": \"/amazon/${ASIN}\"}")
            ALL_PATHS=$(echo "$LIST_JSON" | python3 -c "import sys,json; e=sorted([x for x in json.load(sys.stdin).get('entries',[]) if x.get('.tag')=='file'],key=lambda x:x.get('name','')); print(chr(10).join(x['path_lower'] for x in e))" 2>/dev/null || echo "")
          fi

          mapfile -t PATH_ARRAY <<< "$ALL_PATHS"

          dbx_dl() {
            [ -z "$1" ] || [ -z "$DBX_TOKEN" ] && return 1
            curl -s -X POST https://content.dropboxapi.com/2/files/download \
              --header "Authorization: Bearer $DBX_TOKEN" \
              --header "Dropbox-API-Arg: {\"path\": \"$1\"}" -o "$2"
            [ -s "$2" ]
          }

          dbx_dl "${PATH_ARRAY[0]:-}" assets/cover.jpg && echo "Cover: Dropbox OK" || {
            IMG=$(curl -sL -A "$UA" -H "Accept-Language: en-US,en;q=0.9" "$PRODUCT_URL" | grep -oP '(?<=property="og:image" content=")[^"]+' | head -1)
            [ -n "$IMG" ] && curl -sL -A "$UA" "$IMG" -o assets/cover.jpg || true
            [ -s assets/cover.jpg ] && echo "Cover: scrape OK" || { ffmpeg -f lavfi -i color=c=0x4A1F42:s=900x900 -frames:v 1 -y assets/cover.jpg; echo "::warning::Cover fallback for $PRODUCT_NAME"; }
          }

          COLORS=("0xC8A656" "0x6B5F54" "0x371531")
          for i in 0 1 2; do
            n=$((i+1))
            dbx_dl "${PATH_ARRAY[$((i+1))]:-}" "assets/sample${n}.jpg" && echo "Sample $n: OK" || \
              { ffmpeg -f lavfi -i color=c=${COLORS[$i]}:s=900x900 -frames:v 1 -y "assets/sample${n}.jpg"; echo "Sample $n: fallback"; }
          done

      - name: Lint composition
        run: npx hyperframes lint

      - name: Render to MP4
        run: npx hyperframes render -o "output-${PRODUCT_NAME}.mp4"

      - name: Upload to Dropbox
        env:
          DROPBOX_APP_KEY:      ${{ secrets.DROPBOX_APP_KEY }}
          DROPBOX_APP_SECRET:   ${{ secrets.DROPBOX_APP_SECRET }}
          DROPBOX_REFRESH_TOKEN: ${{ secrets.DROPBOX_REFRESH_TOKEN }}
        run: |
          [ -z "$DROPBOX_APP_KEY" ] && echo "::warning::Thiếu Dropbox Secrets" && exit 0
          TOKEN=$(curl -s https://api.dropbox.com/oauth2/token \
            -d grant_type=refresh_token \
            -d refresh_token="$DROPBOX_REFRESH_TOKEN" \
            -d client_id="$DROPBOX_APP_KEY" \
            -d client_secret="$DROPBOX_APP_SECRET" \
            | python3 -c "import sys,json; print(json.load(sys.stdin).get('access_token',''))")
          STAMP=$(date +%Y%m%d-%H%M%S)
          DEST="/${PRODUCT_NAME}-${STAMP}.mp4"
          CODE=$(curl -s -o /tmp/dbx_resp.json -w "%{http_code}" \
            -X POST https://content.dropboxapi.com/2/files/upload \
            --header "Authorization: Bearer $TOKEN" \
            --header "Dropbox-API-Arg: {\"path\":\"$DEST\",\"mode\":\"add\",\"autorename\":true}" \
            --header "Content-Type: application/octet-stream" \
            --data-binary @"output-${PRODUCT_NAME}.mp4")
          [ "$CODE" = "200" ] && echo "Uploaded: $DEST" || { cat /tmp/dbx_resp.json; exit 1; }

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: video-${{ matrix.name }}
          path: output-${{ matrix.name }}.mp4
          retention-days: 14

  summary:
    needs: render
    runs-on: ubuntu-latest
    if: always()
    steps:
      - name: Done
        run: echo "## Batch render hoàn tất — kiểm tra từng job để xem chi tiết" >> $GITHUB_STEP_SUMMARY

name: Generate Narration Scripts

# Chạy riêng, trước khi render video.
# Kết quả: 26 file narration-01..26.txt tự commit vào assets/ trên repo.

on:
  workflow_dispatch:
    inputs:
      amazon_url:
        description: "Link sản phẩm Amazon"
        required: true
        type: string
      ai_provider:
        description: "AI provider (claude / openai / deepseek)"
        required: false
        default: "deepseek"
        type: choice
        options:
          - deepseek
          - claude
          - openai

jobs:
  generate:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    permissions:
      contents: write   # cần để commit file vào repo
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Generate 26 narration chunks via AI
        env:
          AMAZON_URL:       ${{ github.event.inputs.amazon_url }}
          AI_PROVIDER:      ${{ github.event.inputs.ai_provider }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          OPENAI_API_KEY:   ${{ secrets.OPENAI_API_KEY }}
          DEEPSEEK_API_KEY: ${{ secrets.DEEPSEEK_API_KEY }}
        run: python3 scripts/generate_narration.py "$AMAZON_URL"

      - name: Show generated files
        run: |
          echo "=== 26 files generated ==="
          for f in assets/narration-*.txt; do
            echo "$f: $(cat $f)"
          done

      - name: Commit narration files back to repo
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add assets/narration-*.txt
          git diff --cached --quiet && echo "No changes to commit." || \
            git commit -m "auto: regenerate narration for $(echo '${{ github.event.inputs.amazon_url }}' | grep -oP '(?:/dp/|/product/)\K[A-Z0-9]{10}' || echo 'new product')"
          git push

name: Render Amazon Review Video

# Bấm "Run workflow" trong tab Actions để chạy.
# Khi xong (~6-10 phút), vào lần chạy đó -> "Artifacts" ở cuối trang -> tải về.

on:
  workflow_dispatch:
    inputs:
      amazon_url:
        description: "Amazon product URL (để tải ảnh bìa thật)"
        required: false
        default: "https://www.amazon.com/Simple-Christian-Devotional-Relaxation-Reflections/dp/B0F7FBZNMZ"
        type: string
      dropbox_filename:
        description: "Tên file khi lưu vào Dropbox (không cần .mp4)"
        required: false
        default: "simple-christian-review"
        type: string

jobs:
  render:
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Node.js 22
        uses: actions/setup-node@v4
        with:
          node-version: 22

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install ffmpeg
        run: sudo apt-get update && sudo apt-get install -y ffmpeg

      - name: Install hyperframes CLI
        run: npm install hyperframes --no-save --ignore-scripts

      - name: Install local TTS engine (Kokoro)
        run: pip install kokoro-onnx soundfile --break-system-packages

      - name: Download headless Chrome for rendering
        run: npx hyperframes browser ensure

      - name: Generate narration audio (24 short chunks, looped)
        run: |
          for f in assets/narration-*.txt; do
            n=$(basename "$f" .txt | sed 's/narration-//')
            echo "=== Chunk $n: $(cat "$f") ==="
            npx hyperframes tts "$f" -o "voice-${n}.wav" -v af_heart
          done

      - name: Concatenate narration chunks into a single audio file
        run: |
          : > concat-list.txt
          for f in voice-*.wav; do
            echo "file '$f'" >> concat-list.txt
          done
          cat concat-list.txt
          ffmpeg -f concat -safe 0 -i concat-list.txt -c:a pcm_s16le -ar 24000 -ac 1 -y narration-full.wav
          ffprobe -v quiet -show_entries format=duration -of default=noprint_wrappers=1 narration-full.wav

      - name: Measure real narration lengths and sync timeline
        run: python3 scripts/build_timing.py

      - name: Fetch product images (cover + 3 sample pages; Dropbox first, then scrape, then fallback)
        env:
          DROPBOX_APP_KEY: ${{ secrets.DROPBOX_APP_KEY }}
          DROPBOX_APP_SECRET: ${{ secrets.DROPBOX_APP_SECRET }}
          DROPBOX_REFRESH_TOKEN: ${{ secrets.DROPBOX_REFRESH_TOKEN }}
        run: |
          UA="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
          URL="${{ github.event.inputs.amazon_url }}"

          dbx_download() {
            local path="$1"
            local out="$2"
            if [ -z "$path" ] || [ -z "$DBX_TOKEN" ]; then
              return 1
            fi
            curl -s -X POST https://content.dropboxapi.com/2/files/download \
              --header "Authorization: Bearer $DBX_TOKEN" \
              --header "Dropbox-API-Arg: {\"path\": \"$path\"}" \
              -o "$out"
            [ -s "$out" ]
          }

          # Tách ASIN từ link Amazon (vd: .../dp/B0F7FBZNMZ -> B0F7FBZNMZ)
          ASIN=$(echo "$URL" | grep -oP '(?:/dp/|/product/|/gp/product/)\K[A-Z0-9]{10}' | head -1)
          echo "Detected ASIN: ${ASIN:-(none)}"

          DBX_TOKEN=""
          COVER_PATH=""
          SAMPLE1_PATH=""
          SAMPLE2_PATH=""
          SAMPLE3_PATH=""

          # ---- Liệt kê toàn bộ ảnh có sẵn trong Dropbox /amazon/<ASIN>/ ----
          # (thư mục này được tool "Amazon Ảnh" trong Video Merger Pro tự tạo,
          # pipeline trích ảnh đó đáng tin hơn scrape trực tiếp từ máy chủ GitHub)
          if [ -n "$ASIN" ] && [ -n "$DROPBOX_APP_KEY" ] && [ -n "$DROPBOX_APP_SECRET" ] && [ -n "$DROPBOX_REFRESH_TOKEN" ]; then
            DBX_TOKEN=$(curl -s https://api.dropbox.com/oauth2/token \
              -d grant_type=refresh_token \
              -d refresh_token="$DROPBOX_REFRESH_TOKEN" \
              -d client_id="$DROPBOX_APP_KEY" \
              -d client_secret="$DROPBOX_APP_SECRET" \
              | python3 -c "import sys, json; print(json.load(sys.stdin).get('access_token',''))")

            if [ -n "$DBX_TOKEN" ]; then
              DBX_FOLDER="/amazon/${ASIN}"
              echo "Checking Dropbox folder: $DBX_FOLDER"
              LIST_JSON=$(curl -s -X POST https://api.dropboxapi.com/2/files/list_folder \
                --header "Authorization: Bearer $DBX_TOKEN" \
                --header "Content-Type: application/json" \
                --data "{\"path\": \"$DBX_FOLDER\"}")

              ALL_PATHS=$(echo "$LIST_JSON" | python3 -c "import sys, json; e = sorted([x for x in json.load(sys.stdin).get('entries', []) if x.get('.tag') == 'file'], key=lambda x: x.get('name','')); print(chr(10).join(x['path_lower'] for x in e))" 2>/dev/null || echo "")

              mapfile -t PATH_ARRAY <<< "$ALL_PATHS"
              echo "Found ${#PATH_ARRAY[@]} file(s) in $DBX_FOLDER"
              COVER_PATH="${PATH_ARRAY[0]:-}"
              SAMPLE1_PATH="${PATH_ARRAY[1]:-}"
              SAMPLE2_PATH="${PATH_ARRAY[2]:-}"
              SAMPLE3_PATH="${PATH_ARRAY[3]:-}"
            else
              echo "Không lấy được Dropbox access token -- kiểm tra lại 3 Secrets."
            fi
          fi

          # ---- Ảnh bìa: Dropbox -> scrape trực tiếp -> khối màu ----
          COVER_FOUND=false
          if dbx_download "$COVER_PATH" assets/cover.jpg; then
            COVER_FOUND=true
            echo "Cover: dùng ảnh thật từ Dropbox ($COVER_PATH)."
          else
            echo "Cover: Dropbox chưa có -- thử scrape trực tiếp trang Amazon..."
            curl -sL -A "$UA" -H "Accept-Language: en-US,en;q=0.9" "$URL" -o product_page.html || true
            IMG_URL=""
            if [ -s product_page.html ]; then
              IMG_URL=$(grep -oP '(?<=property="og:image" content=")[^"]+' product_page.html | head -1)
            fi
            if [ -n "$IMG_URL" ]; then
              curl -sL -A "$UA" "$IMG_URL" -o assets/cover.jpg || true
              [ -s assets/cover.jpg ] && COVER_FOUND=true
            fi
          fi
          if [ "$COVER_FOUND" = "false" ]; then
            echo "Cover: không lấy được ảnh thật -- dùng khối màu thay thế."
            ffmpeg -f lavfi -i color=c=0x4A1F42:s=900x900 -frames:v 1 -y assets/cover.jpg
            echo "::warning::Không lấy được ảnh bìa thật (Dropbox lẫn scrape Amazon đều thất bại) -- dùng khối màu thay thế."
          fi

          # ---- 3 ảnh mẫu cho cảnh "A Peek Inside": Dropbox -> khối màu ----
          # (không có nguồn scrape thay thế cho ảnh trang ruột, nên fallback thẳng khối màu)
          SAMPLE_PATHS=("$SAMPLE1_PATH" "$SAMPLE2_PATH" "$SAMPLE3_PATH")
          SAMPLE_COLORS=("0xC8A656" "0x6B5F54" "0x371531")
          for i in 0 1 2; do
            n=$((i + 1))
            if dbx_download "${SAMPLE_PATHS[$i]}" "assets/sample${n}.jpg"; then
              echo "Sample $n: dùng ảnh thật từ Dropbox (${SAMPLE_PATHS[$i]})."
            else
              echo "Sample $n: chưa có ảnh trong Dropbox -- dùng khối màu thay thế."
              ffmpeg -f lavfi -i color=c=${SAMPLE_COLORS[$i]}:s=900x900 -frames:v 1 -y "assets/sample${n}.jpg"
            fi
          done

          if [ -z "$SAMPLE1_PATH" ] && [ -z "$SAMPLE2_PATH" ] && [ -z "$SAMPLE3_PATH" ]; then
            echo "::warning::Không có ảnh mẫu nào trong $DBX_FOLDER ngoài ảnh bìa -- cảnh 'A Peek Inside' đang dùng khối màu thay thế. Hãy chạy tab Amazon Ảnh trong Video Merger Pro để có đủ ảnh trang ruột."
          fi

      - name: Lint composition
        run: npx hyperframes lint

      - name: Render to MP4
        run: npx hyperframes render -o output.mp4

      - name: Upload video to Dropbox
        env:
          DROPBOX_APP_KEY: ${{ secrets.DROPBOX_APP_KEY }}
          DROPBOX_APP_SECRET: ${{ secrets.DROPBOX_APP_SECRET }}
          DROPBOX_REFRESH_TOKEN: ${{ secrets.DROPBOX_REFRESH_TOKEN }}
        run: |
          if [ -z "$DROPBOX_APP_KEY" ] || [ -z "$DROPBOX_APP_SECRET" ] || [ -z "$DROPBOX_REFRESH_TOKEN" ]; then
            echo "::warning::Thiếu DROPBOX_APP_KEY / DROPBOX_APP_SECRET / DROPBOX_REFRESH_TOKEN trong Secrets -- bỏ qua bước upload Dropbox. Video vẫn có trong Artifacts."
            exit 0
          fi

          ACCESS_TOKEN=$(curl -s https://api.dropbox.com/oauth2/token \
            -d grant_type=refresh_token \
            -d refresh_token="$DROPBOX_REFRESH_TOKEN" \
            -d client_id="$DROPBOX_APP_KEY" \
            -d client_secret="$DROPBOX_APP_SECRET" \
            | python3 -c "import sys, json; d = json.load(sys.stdin); print(d.get('access_token',''))")

          if [ -z "$ACCESS_TOKEN" ]; then
            echo "::error::Không lấy được access token từ Dropbox -- kiểm tra lại 3 Secrets (App Key / App Secret / Refresh Token)."
            exit 1
          fi

          RAW_NAME="${{ github.event.inputs.dropbox_filename }}"
          SAFE_NAME="${RAW_NAME:-simple-christian-review}"
          STAMP=$(date +%Y%m%d-%H%M%S)
          DROPBOX_PATH="/${SAFE_NAME}-${STAMP}.mp4"

          echo "Uploading to Dropbox path: $DROPBOX_PATH"
          HTTP_CODE=$(curl -s -o upload_response.json -w "%{http_code}" -X POST https://content.dropboxapi.com/2/files/upload \
            --header "Authorization: Bearer $ACCESS_TOKEN" \
            --header "Dropbox-API-Arg: {\"path\": \"$DROPBOX_PATH\",\"mode\": \"add\",\"autorename\": true,\"mute\": false}" \
            --header "Content-Type: application/octet-stream" \
            --data-binary @output.mp4)

          cat upload_response.json
          if [ "$HTTP_CODE" != "200" ]; then
            echo "::error::Dropbox upload thất bại (HTTP $HTTP_CODE). Xem chi tiết log ở trên. Video vẫn có trong Artifacts."
            exit 1
          fi
          echo "Đã upload thành công lên Dropbox: $DROPBOX_PATH"

      - name: Upload rendered video
        uses: actions/upload-artifact@v4
        with:
          name: amazon-review-video
          path: output.mp4
          retention-days: 14

      - name: Upload narration audio (for reference / re-use)
        uses: actions/upload-artifact@v4
        with:
          name: narration-audio
          path: |
            voice-*.wav
            narration-full.wav
          retention-days: 14
